# Server
PORT=8787
HOST=0.0.0.0
CORS_ORIGIN=*

# Model Gateway
MODEL_OVERRIDE_ENABLED=false
DEFAULT_MODEL_KEY=deepseek_chat
MODEL_ALLOWLIST=deepseek_chat,deepseek_reasoner,doubao_chat,openai_gpt4o_mini
LLM_TIMEOUT_MS=8000

# DeepSeek
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Doubao (Volcengine Ark-compatible)
DOUBAO_API_KEY=YOUR_DOUBAO_API_KEY
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_ID=YOUR_DOUBAO_MODEL_ID

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Frontend remote API settings
VITE_API_BASE_URL=http://127.0.0.1:8787
VITE_API_TIMEOUT_MS=10000

# Controlled Web Search
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=serper
WEB_SEARCH_API_KEY=
WEB_SEARCH_TIMEOUT_MS=5000
WEB_SEARCH_TOP_K=5
WEB_SEARCH_ALLOWLIST=nhc.gov.cn,who.int,acog.org,mayoclinic.org,cdc.gov,nhs.uk
WEB_SEARCH_SERPER_BASE_URL=https://google.serper.dev
WEB_SEARCH_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
WEB_SEARCH_ZHIPU_ENGINE=search_std
WEB_SEARCH_ZHIPU_CONTENT_SIZE=medium
WEB_SEARCH_ZHIPU_RECENCY_FILTER=noLimit
WEB_SEARCH_ZHIPU_SEARCH_INTENT=false

# Nutrition photo analysis (optional)
NUTRITION_PHOTO_PROVIDER=mock
NUTRITION_PHOTO_TIMEOUT_MS=10000
LOGMEAL_API_KEY=
LOGMEAL_BASE_URL=https://api.logmeal.com
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_VISION_MODEL=glm-5v-turbo
ZHIPU_VISION_TIMEOUT_MS=15000

# Feishu knowledge live lookup (optional)
FEISHU_KB_LIVE_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_KB_SYNC_ENABLED=true
FEISHU_KB_SYNC_INTERVAL_MINUTES=720
FEISHU_KB_SYNC_FILE=server/data/feishu-knowledge.local.json
FEISHU_KB_TARGETS_FILE=server/data/feishu-sync-targets.local.json

# Unified knowledge base
KNOWLEDGE_BASE_ENABLED=true
KNOWLEDGE_BASE_DEFAULT_TENANT=rihea-default
KNOWLEDGE_BASE_DOCUMENTS_FILE=server/kb/knowledge-documents.local.json
KNOWLEDGE_BASE_SOURCE_REGISTRY_FILE=server/kb/knowledge-connectors.local.json
