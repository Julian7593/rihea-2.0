{
  "name": "rihea-landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node --env-file=.env server/index.js",
    "server:dev": "node --env-file=.env --watch server/index.js",
    "check:feishu-kb": "node --env-file=.env server/scripts/checkFeishuAccess.js",
    "check:web-search": "node --env-file=.env server/scripts/checkWebSearch.js",
    "sync:feishu": "node --env-file=.env server/scripts/syncFeishuKnowledge.js",
    "sync:feishu-kb": "node --env-file=.env server/scripts/syncFeishuKnowledge.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "coverage": "vitest --coverage",
    "verify": "npm run test:run && npm run build"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "rollup": "^4.59.0"
  }
}
